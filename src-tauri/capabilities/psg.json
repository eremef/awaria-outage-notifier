[
  {
    "$schema": "../gen/schemas/desktop-schema.json",
    "identifier": "psg-fetcher",
    "description": "enables PSG fetcher permissions on the PSG website",
    "windows": [
      "psg_fetcher"
    ],
    "permissions": [
      "core:default",
      "core:event:allow-emit",
      "core:event:allow-listen"
    ],
    "remote": {
      "urls": ["https://www.psgaz.pl/*"]
    }
  }
]
