<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="2dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="1dp"
        android:paddingHorizontal="2dp">
        
        <TextView
            android:id="@+id/widget_address_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text=""
            android:textColor="#999999"
            android:textSize="10sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end"
            android:maxWidth="100dp" />

        <TextView
            android:id="@+id/widget_updated"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:text="--:--"
            android:textColor="#999999"
            android:textSize="8sp" />
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:weightSum="3">

        <!-- Power -->
        <LinearLayout
            android:id="@+id/section_power"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:id="@+id/icon_power"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_electricity"
                android:contentDescription="@null" />
            <TextView
                android:id="@+id/count_power"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="–"
                android:textColor="#D9006C"
                android:textSize="14sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/label_power"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_power"
                android:textColor="#666666"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Heat -->
        <LinearLayout
            android:id="@+id/section_heat"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:id="@+id/icon_heat"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_heating"
                android:contentDescription="@null" />
            <TextView
                android:id="@+id/count_heat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="–"
                android:textColor="#00A859"
                android:textSize="14sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/label_heat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_heat"
                android:textColor="#666666"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Water -->
        <LinearLayout
            android:id="@+id/section_water"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:id="@+id/icon_water"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_water"
                android:contentDescription="@null" />
            <TextView
                android:id="@+id/count_water"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="–"
                android:textColor="#0077D9"
                android:textSize="14sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/label_water"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_water"
                android:textColor="#666666"
                android:textSize="10sp" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
