{
  "name": "awaria",
  "version": "1.0.27",
  "description": "Outage notifier — Tauri desktop & Android app",
  "scripts": {
    "tauri": "tauri",
    "build": "tauri build",
    "dev": "tauri dev",
    "android:build": "tauri android build",
    "android:dev": "tauri android dev",
    "version:bump": "node scripts/bump-version.mjs",
    "ios:build": "tauri ios build",
    "ios:init": "tauri ios init --ci",
    "test": "npm run test:frontend && npm run test:backend && npm run test:android",
    "test:frontend": "vitest run",
    "test:backend": "cd src-tauri && cargo test",
    "test:android": "cd src-tauri/gen/android && gradlew.bat :app:testUniversalDebugUnitTest",
    "load:teryt": "node scripts/load-teryt.mjs"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@vitest/coverage-v8": "^4.0.18",
    "better-sqlite3": "^11.9.1",
    "jsdom": "^28.0.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@tauri-apps/plugin-opener": "^2.5.3"
  }
}